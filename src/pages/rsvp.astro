---
export const prerender = false;

import { env } from 'cloudflare:workers';
import Layout from '../layouts/Layout.astro';
import HeartAccent from '../components/HeartAccent.astro';
import { CONTACT_EMAIL, RSVP_DEADLINE_LABEL } from '../consts';

const status = Astro.url.searchParams.get('status');
const turnstileSiteKey = env.TURNSTILE_SITE_KEY;
---

<Layout title="RSVP" description={`Laat ons voor ${RSVP_DEADLINE_LABEL} weten of je erbij kan zijn.`}>
	<span class="eyebrow"><HeartAccent /> RSVP <HeartAccent /></span>
	<h1>Doe je mee?</h1>
	<p>
		Laat ons voor <strong>{RSVP_DEADLINE_LABEL}</strong> weten of je erbij kan zijn. Heb je toch nog
		vragen, mail dan naar <a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>.
	</p>

	{
		status === 'success' && (
			<p class="notice notice-success">Bedankt! We hebben je RSVP goed ontvangen.</p>
		)
	}
	{
		status === 'error' && (
			<p class="notice notice-error">
				Er ging iets mis bij het versturen. Probeer het opnieuw of mail naar {CONTACT_EMAIL}.
			</p>
		)
	}

	<form class="card" method="POST" action="/api/rsvp">
		<div class="field honeypot" aria-hidden="true">
			<label for="website">Laat dit veld leeg</label>
			<input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
		</div>

		<div class="field">
			<label for="naam">Naam*</label>
			<input type="text" id="naam" name="naam" required maxlength="100" />
		</div>

		<div class="field">
			<label for="email">E-mail*</label>
			<input
				type="email"
				id="email"
				name="email"
				required
				maxlength="254"
				pattern="[^\s@]+@[^\s@]+\.[^\s@]+"
				aria-describedby="email-error"
			/>
			<span id="email-error" class="field-error" hidden>Vul een geldig e-mailadres in.</span>
		</div>

		<fieldset class="field">
			<legend>Ben je erbij?*</legend>
			<label class="radio"><input type="radio" name="aanwezig" value="ja" required /> Ja, graag!</label>
			<label class="radio"><input type="radio" name="aanwezig" value="nee" required /> Helaas, ik kan niet.</label>
		</fieldset>

		<div class="field">
			<label for="aantal_gasten">Aantal gasten (inclusief jezelf)</label>
			<input type="number" id="aantal_gasten" name="aantal_gasten" min="1" max="20" value="1" />
		</div>

		<div class="field">
			<label for="dieetwensen">Dieetwensen of allergieën</label>
			<textarea id="dieetwensen" name="dieetwensen" rows="3" maxlength="500"></textarea>
		</div>

		<div class="field">
			<label for="bericht">Bericht voor het bruidspaar</label>
			<textarea id="bericht" name="bericht" rows="3" maxlength="1000"></textarea>
		</div>

		<div class="cf-turnstile" data-sitekey={turnstileSiteKey}></div>

		<button type="submit" class="btn btn-solid">Versturen</button>
	</form>
</Layout>

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script>
	const emailInput = document.querySelector<HTMLInputElement>('#email');
	const emailError = document.querySelector<HTMLElement>('#email-error');

	function validateEmail() {
		if (!emailInput || !emailError) return;
		emailInput.setCustomValidity('');
		const isValid = emailInput.validity.valid;
		emailInput.setCustomValidity(isValid ? '' : 'Vul een geldig e-mailadres in.');
		emailError.hidden = isValid;
		emailInput.setAttribute('aria-invalid', String(!isValid));
	}

	emailInput?.addEventListener('input', validateEmail);
	emailInput?.addEventListener('blur', validateEmail);
</script>

<style>
	.notice {
		padding: 1em;
		border-radius: 8px;
	}
	.notice-success {
		background: rgba(178, 106, 58, 0.15);
		color: var(--accent-dark);
	}
	.notice-error {
		background: rgba(178, 58, 58, 0.1);
		color: #8a2c2c;
	}
	.field-error {
		color: #8a2c2c;
		font-size: 0.9em;
	}
	form {
		margin-top: 2em;
		display: flex;
		flex-direction: column;
		gap: 1.25em;
	}
	.field {
		display: flex;
		flex-direction: column;
		gap: 0.4em;
		border: none;
		padding: 0;
		margin: 0;
	}
	.honeypot {
		position: absolute;
		width: 1px;
		height: 1px;
		overflow: hidden;
		left: -9999px;
	}
	.field legend {
		font-weight: 700;
		padding: 0;
		margin-bottom: 0.2em;
	}
	label {
		font-weight: 700;
	}
	.radio {
		display: flex;
		align-items: center;
		gap: 0.5em;
		font-weight: 400;
	}
	input[type='text'],
	input[type='email'],
	input[type='number'],
	textarea {
		font-family: inherit;
		padding: 0.6em 0.75em;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 8px;
		color: rgb(var(--gray-dark));
	}
	input[aria-invalid='true'] {
		border-color: #8a2c2c;
	}
	button {
		align-self: flex-start;
		font-size: 1rem;
		cursor: pointer;
		border-width: 2px;
		border-style: solid;
	}
</style>
