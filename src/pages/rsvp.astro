b---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import { CONTACT_EMAIL, RSVP_DEADLINE_LABEL } from '../consts';

const status = Astro.url.searchParams.get('status');
---

<Layout title="RSVP" description={`Laat ons voor ${RSVP_DEADLINE_LABEL} weten of je erbij kan zijn.`}>
	<span class="eyebrow">RSVP</span>
	<h1>Doe je mee?</h1>
	<p>
		Laat ons voor <strong>{RSVP_DEADLINE_LABEL}</strong> weten of je erbij kan zijn. Heb je toch nog
		vragen, mail dan naar <a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>.
	</p>

	{
		status === 'success' && (
			<p class="notice notice-success">Bedankt! We hebben je RSVP goed ontvangen.</p>
		)
	}
	{
		status === 'error' && (
			<p class="notice notice-error">
				Er ging iets mis bij het versturen. Probeer het opnieuw of mail naar {CONTACT_EMAIL}.
			</p>
		)
	}

	<form class="card" method="POST" action="/api/rsvp">
		<div class="field">
			<label for="naam">Naam*</label>
			<input type="text" id="naam" name="naam" required />
		</div>

		<div class="field">
			<label for="email">E-mail*</label>
			<input type="email" id="email" name="email" required />
		</div>

		<fieldset class="field">
			<legend>Ben je erbij?*</legend>
			<label class="radio"><input type="radio" name="aanwezig" value="ja" required /> Ja, graag!</label>
			<label class="radio"><input type="radio" name="aanwezig" value="nee" required /> Helaas, ik kan niet.</label>
		</fieldset>

		<div class="field">
			<label for="aantal_gasten">Aantal gasten (inclusief jezelf)</label>
			<input type="number" id="aantal_gasten" name="aantal_gasten" min="1" value="1" />
		</div>

		<div class="field">
			<label for="dieetwensen">Dieetwensen of allergieën</label>
			<textarea id="dieetwensen" name="dieetwensen" rows="3"></textarea>
		</div>

		<div class="field">
			<label for="bericht">Bericht voor het bruidspaar</label>
			<textarea id="bericht" name="bericht" rows="3"></textarea>
		</div>

		<button type="submit" class="btn btn-solid">Versturen</button>
	</form>
</Layout>

<style>
	.notice {
		padding: 1em;
		border-radius: 8px;
	}
	.notice-success {
		background: rgba(178, 106, 58, 0.15);
		color: var(--accent-dark);
	}
	.notice-error {
		background: rgba(178, 58, 58, 0.1);
		color: #8a2c2c;
	}
	form {
		margin-top: 2em;
		display: flex;
		flex-direction: column;
		gap: 1.25em;
	}
	.field {
		display: flex;
		flex-direction: column;
		gap: 0.4em;
		border: none;
		padding: 0;
		margin: 0;
	}
	.field legend {
		font-weight: 700;
		padding: 0;
		margin-bottom: 0.2em;
	}
	label {
		font-weight: 700;
	}
	.radio {
		display: flex;
		align-items: center;
		gap: 0.5em;
		font-weight: 400;
	}
	input[type='text'],
	input[type='email'],
	input[type='number'],
	textarea {
		font-family: inherit;
		padding: 0.6em 0.75em;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 8px;
		color: rgb(var(--gray-dark));
	}
	button {
		align-self: flex-start;
		font-size: 1rem;
		cursor: pointer;
		border-width: 2px;
		border-style: solid;
	}
</style>
